<%- include('layout/header', { title: '微博 - 黑名单管理', isNav: true, list: true })%>

<div class="container margin-top-20">
    <div class="row">
        <!-- 左侧 -->
        <div class="col-8">
            <h4 class="margin-bottom-20 padding-bottom-10 border-bottom">
                <i class="fa fa-ban"></i> 黑名单管理（<%= blockedCount %>）
            </h4>

            <% if (blockedList.length === 0) { %>
                <div>
                    <center>暂无屏蔽用户</center>
                </div>
            <% } else { %>
                <div class="user-list">
                    <% blockedList.forEach(function(user) { %>
                        <div class="user-item margin-bottom-20 padding-bottom-20 border-bottom clear-fix" data-user-id="<%= user.id %>">
                            <a href="/profile/<%= user.userName %>" class="float-left">
                                <img src="<%= user.picture %>" class="header-img"/>
                            </a>
                            <div class="float-left margin-left-20">
                                <h5>
                                    <a href="/profile/<%= user.userName %>" class="text-dark">
                                        <%= user.nickName %>
                                    </a>
                                </h5>
                                <p class="text-muted small">@<%= user.userName %></p>
                                <% if (user.intro) { %>
                                    <p class="text-muted small"><%= user.intro %></p>
                                <% } %>
                            </div>
                            <div class="float-right">
                                <button class="btn btn-danger btn-sm unblock-btn" data-user-id="<%= user.id %>">
                                    取消屏蔽
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div> <!-- 左侧结束 -->

        <!-- 右侧 -->
        <div class="col-4">
            <!-- 个人信息 -->
            <div class="right-item">
                <%- include('widgets/user-info', {
                    userInfo: userInfo,
                    isMe: true,
                    amIFollowed: false,
                    followersData: {
                        count: 0,
                        list: []
                    },
                    fansData: {
                        count: 0,
                        list: []
                    }
                });%>
            </div>
        </div> <!-- 右侧结束 -->
    </div>
</div>

<%- include('layout/footer')%>

<script>
$(function() {
    // 取消屏蔽
    $('.unblock-btn').click(function() {
        var $btn = $(this);
        var userId = $btn.data('user-id');
        var $userItem = $btn.closest('.user-item');
        
        if (confirm('确定要取消屏蔽该用户吗？')) {
            ajax.post('/api/block/cancel', {
                blockedId: userId
            }, function(err, data) {
                if (err) {
                    alert(err);
                    return;
                }
                $userItem.fadeOut(300, function() {
                    $userItem.remove();
                    alert('已取消屏蔽该用户');
                    location.reload();
                });
            });
        }
    });
});
</script>
