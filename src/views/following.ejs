<%- include('layout/header', { title: '微博 - 关注列表', isNav: true, list: true })%>

<div class="container margin-top-20">
    <div class="row">
        <!-- 左侧 -->
        <div class="col-8">
            <h4 class="margin-bottom-20 padding-bottom-10 border-bottom">
                <i class="fa fa-users"></i> 关注列表（<%= userData.count %>）
            </h4>

            <% if (userData.list.length === 0) { %>
                <div>
                    <center>暂无关注</center>
                </div>
            <% } else { %>
                <div class="user-list">
                    <% userData.list.forEach(user => { %>
                        <div class="user-item margin-bottom-20 padding-bottom-20 border-bottom clear-fix">
                            <a href="/profile/<%= user.userName %>" class="float-left">
                                <img src="<%= user.picture %>" class="header-img"/>
                            </a>
                            <div class="float-left margin-left-20">
                                <h5>
                                    <a href="/profile/<%= user.userName %>" class="text-dark">
                                        <%= user.nickName %>
                                    </a>
                                </h5>
                                <p class="text-muted small">@<%= user.userName %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div> <!-- 左侧结束 -->

        <!-- 右侧 -->
        <div class="col-4">
            <!-- 个人信息 -->
            <div class="right-item">
                <%- include('widgets/user-info', {
                    userInfo: userData.userInfo,
                    isMe: userData.isMe,
                    amIFollowed: false,
                    followersData: userData.followersData,
                    fansData: userData.fansData
                });%>
            </div>
        </div> <!-- 右侧结束 -->
    </div>
</div>

<%- include('layout/footer')%>