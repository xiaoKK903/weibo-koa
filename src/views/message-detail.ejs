</style>

<script>
function escapeHtml(text) {
    if (!text) return '';
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

$(function () {
    var currentUserId = <%= currentUserId %>;
    var targetUserId = <%= targetUser.id %>;
    var targetUserNickName = <%- JSON.stringify(targetUser.nickName) %>;
    var targetUserPicture = <%- JSON.stringify(targetUser.picture) %>;
    var currentUserPicture = <%- JSON.stringify(userData.userInfo.picture) %>;
    var currentUserNickName = <%- JSON.stringify(userData.userInfo.nickName) %>;
    
    var $messageInput = $('#message-input');
    var $sendBtn = $('#send-btn');
    var $charCount = $('#char-count');
    var $chatMessages = $('#chat-messages');
    var maxChars = 500;
    
    function scrollToBottom() {
        setTimeout(function () {
            $chatMessages.scrollTop($chatMessages[0].scrollHeight);
        }, 100);
    }
    
    scrollToBottom();
    
    function updateCharCount() {
        var text = $messageInput.val();
        var count = text.length;
        
        $charCount.text(count + '/' + maxChars);
        
        $charCount.removeClass('warning error');
        if (count > maxChars) {
            $charCount.addClass('error');
        } else if (count > maxChars * 0.8) {
            $charCount.addClass('warning');
        }
        
        var canSend = count > 0 && count <= maxChars && text.trim() !== '';
        $sendBtn.prop('disabled', !canSend);
    }
    
    $messageInput.on('input', updateCharCount);
    
    function autoResize() {
        $messageInput.css('height', 'auto');
        $messageInput.css('height', Math.min($messageInput[0].scrollHeight, 120) + 'px');
    }
    
    $messageInput.on('input', autoResize);
    
    function formatMessageTime(date) {
        var d = new Date(date);
        var hours = d.getHours();
        var minutes = d.getMinutes();
        var month = d.getMonth() + 1;
        var day = d.getDate();
        return month + '-' + (day < 10 ? '0' + day : day) + ' ' + (hours < 10 ? '0' + hours : hours) + ':' + (minutes < 10 ? '0' + minutes : minutes);
    }
    
    function createMessageHtml(msg) {
        var isMine = msg.isMine;
        var messageClass = isMine ? 'message-mine' : 'message-other';
        var avatar = isMine ? currentUserPicture : (msg.fromUser ? msg.fromUser.picture : targetUserPicture);
        var senderName = isMine ? currentUserNickName : (msg.fromUser ? msg.fromUser.nickName : targetUserNickName);
        
        var bubbleStyle = isMine ? 'background: #007bff; color: #fff; border-top-right-radius: 4px;' : 'background: #fff; color: #333; border-top-left-radius: 4px; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);';
        
        if (isMine) {
            return `
                <div class="chat-message ${messageClass}" data-message-id="${msg.id}">
                    <div class="message-content-wrapper">
                        <div class="message-bubble" style="${bubbleStyle}">${escapeHtml(msg.content)}</div>
                        <div class="message-time">${formatMessageTime(msg.createdAt)}</div>
                    </div>
                    <img src="${avatar}" alt="我" class="message-avatar">
                </div>
            `;
        } else {
            return `
                <div class="chat-message ${messageClass}" data-message-id="${msg.id}">
                    <img src="${avatar}" alt="${escapeHtml(senderName)}" class="message-avatar">
                    <div class="message-content-wrapper">
                        <div class="message-sender">${escapeHtml(senderName)}</div>
                        <div class="message-bubble" style="${bubbleStyle}">${escapeHtml(msg.content)}</div>
                        <div class="message-time">${formatMessageTime(msg.createdAt)}</div>
                    </div>
                </div>
            `;
        }
    }
    
    function sendMessage() {
        var content = $messageInput.val().trim();
        
        if (!content || content.length > maxChars) {
            return;
        }
        
        $sendBtn.prop('disabled', true).text('发送中...');
        $messageInput.prop('disabled', true);
        
        var tempMessage = {
            id: 'temp_' + Date.now(),
            content: content,
            isMine: true,
            createdAt: new Date().toISOString()
        };
        
        if ($chatMessages.find('.chat-empty-messages').length > 0) {
            $chatMessages.html('');
        }
        
        $chatMessages.append(createMessageHtml(tempMessage));
        scrollToBottom();
        
        $messageInput.val('');
        updateCharCount();
        $messageInput.css('height', 'auto');
        
        $.ajax({
            url: '/api/message/create',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                toUserId: targetUserId,
                content: content
            }),
            success: function (res) {
                if (res.errno === 0) {
                    var message = res.data;
                    var $tempMsg = $chatMessages.find('[data-message-id="' + tempMessage.id + '"]');
                    $tempMsg.attr('data-message-id', message.id);
                    
                    updateUnreadCount();
                } else {
                    alert(res.message || '消息发送失败');
                    $chatMessages.find('[data-message-id="' + tempMessage.id + '"]').remove();
                }
            },
            error: function () {
                alert('消息发送失败，请重试');
                $chatMessages.find('[data-message-id="' + tempMessage.id + '"]').remove();
            },
            complete: function () {
                $sendBtn.prop('disabled', false).html('<i class="fa fa-paper-plane"></i> 发送');
                $messageInput.prop('disabled', false);
                $messageInput.focus();
            }
        });
    }
    
    $sendBtn.click(function (e) {
        e.preventDefault();
        sendMessage();
    });
    
    $messageInput.keydown(function (e) {
        if (e.keyCode === 13 && !e.shiftKey) {
            e.preventDefault();
            if (!$sendBtn.prop('disabled')) {
                sendMessage();
            }
        }
    });
    
    function updateUnreadCount() {
        $.ajax({
            url: '/api/message/unread-count',
            type: 'GET',
            success: function (res) {
                if (res.errno === 0) {
                    var count = res.data.count;
                    updateNavUnreadCount(count);
                }
            }
        });
    }
    
    function updateNavUnreadCount(count) {
        var $badge = $('#unread-message-count');
        
        if (count > 0) {
            var displayCount = count > 99 ? '99+' : count;
            if ($badge.length === 0) {
                $('a.nav-link[href="/message"]').append(
                    '<span class="badge badge-danger badge-unread" id="unread-message-count">' + displayCount + '</span>'
                );
            } else {
                $badge.text(displayCount);
            }
        } else {
            $badge.remove();
        }
    }
    
    var emojiData = {
        emoji: ['😀', '😃', '😄', '😁', '😅', '😂', '🤣', '😊', '😇', '🙂', '🙃', '😉', '😍', '🥰', '😘', '😗', '😋', '😛', '😜', '🤪', '😝', '🤑', '🤗', '🤭', '🤫', '🤔', '🤐', '🤨', '😐', '😑', '😶', '😏', '😒', '🙄', '😬', '🤥', '😔', '😪', '🤤', '😴', '😷', '🤒', '🤕', '🤢', '🤮', '🤧', '🥵', '🥶', '😵', '🤯', '🤠', '🥳', '😎', '🤓', '🧐', '😕', '😟', '🙁', '😮', '😯', '😲', '😳', '🥺', '😦', '😧', '😨', '😰', '😥', '😢', '😭', '😱', '😖', '😣', '😞', '😓', '😩', '😫', '🥱', '😤', '😡', '😠', '🤬', '😈', '👿', '💀', '💩', '👻', '👽', '🤖', '🎃'],
        gesture: ['👍', '👎', '👌', '✌', '🤞', '🤟', '🤘', '🤙', '👈', '👉', '👆', '👇', '☝', '✋', '🖐', '🖖', '👋', '🤚', '💪', '🙏', '👏', '❤', '💔', '💕', '💞', '💓', '💗', '💖', '💘', '💝', '💟', '💌'],
        animal: ['🐶', '🐱', '🐭', '🐹', '🐰', '🦊', '🐻', '🐼', '🐨', '🐯', '🦁', '🐮', '🐷', '🐸', '🐵', '🙈', '🙉', '🙊', '🐒', '🐔', '🐧', '🐦', '🐤', '🦆', '🦅', '🦉', '🦇', '🐺', '🐗', '🐴', '🦄', '🐝', '🐛', '🦋', '🐌', '🐞', '🐜', '🐢', '🐍', '🦎', '🐙', '🦑', '🦐', '🦀', '🐡', '🐠', '🐟', '🐬', '🐳', '🐋', '🦈'],
        object: ['⌚', '📱', '💻', '⌨', '🖥', '🖨', '🖱', '🕹', '💽', '💾', '💿', '📀', '📼', '📷', '📸', '📹', '🎥', '📞', '☎', '📟', '📺', '📻', '🎙', '🎚', '🎛', '⏱', '⏲', '⏰', '⌛', '⏳', '🔋', '🔌', '💡', '🔦', '🕯', '💰', '💴', '💶', '💷', '💵', '💸', '💳', '💎', '📧', '📨', '📩', '📤', '📥', '📦', '✉', '📄', '📃', '📑', '📊', '📈', '📉', '📜', '📋', '📰', '🗞']
    };
    
    var $emojiBtn = $('#emoji-btn');
    var $emojiPanel = $('#emoji-panel');
    var $emojiGrid = $('#emoji-grid');
    var $emojiTabs = $('.emoji-tab');
    var currentCategory = 'emoji';
    
    function renderEmojiGrid(category) {
        var emojis = emojiData[category] || emojiData.emoji;
        var html = '';
        emojis.forEach(function(emoji, index) {
            html += '<span class="emoji-item" data-index="' + index + '">' + emoji + '</span>';
        });
        $emojiGrid.html(html);
        $emojiGrid.data('currentEmojis', emojis);
    }
    
    function toggleEmojiPanel() {
        $emojiPanel.toggleClass('show');
    }
    
    function hideEmojiPanel() {
        $emojiPanel.removeClass('show');
    }
    
    function insertEmoji(emoji) {
        var text = $messageInput.val();
        var start = $messageInput[0].selectionStart;
        var end = $messageInput[0].selectionEnd;
        
        var newText = text.substring(0, start) + emoji + text.substring(end);
        $messageInput.val(newText);
        
        var newPos = start + emoji.length;
        $messageInput[0].selectionStart = newPos;
        $messageInput[0].selectionEnd = newPos;
        
        $messageInput.focus();
        updateCharCount();
    }
    
    renderEmojiGrid(currentCategory);
    
    $emojiBtn.on('click', function(e) {
        e.preventDefault();
        $emojiPanel.toggleClass('show');
    });
    
    $emojiTabs.on('click', function() {
        var category = $(this).data('category');
        if (category !== currentCategory) {
            currentCategory = category;
            $emojiTabs.removeClass('active');
            $(this).addClass('active');
            renderEmojiGrid(currentCategory);
        }
    });
    
    $emojiGrid.on('click', '.emoji-item', function() {
        var index = $(this).data('index');
        var emojis = $emojiGrid.data('currentEmojis');
        if (emojis && typeof emojis[index] !== 'undefined') {
            insertEmoji(emojis[index]);
        }
    });
    
    $(document).on('click', function(e) {
        var $target = $(e.target);
        if (!$target.closest('.emoji-panel').length && !$target.closest('#emoji-btn').length) {
            hideEmojiPanel();
        }
    });
    
    $messageInput.focus();
});
</script>
