<%- include('layout/header', { title: '微博 - 私信 - ' + targetUser.nickName, isNav: true, list: true })%>

<div class="container margin-top-20">
    <div class="row">
        <div class="col-4">
            <div class="conversation-list-header d-flex justify-content-between align-items-center">
                <h4>私信</h4>
            </div>
            <div class="conversation-list-container">
                <% if (conversationData.isEmpty) { %>
                    <div class="no-conversation">
                        <div class="text-center">
                            <i class="fa fa-envelope-o" style="font-size: 64px; color: #ccc; margin-bottom: 20px;"></i>
                            <h5 class="text-muted">暂无私信</h5>
                            <p class="text-muted">去关注一些用户，开始聊天吧</p>
                        </div>
                    </div>
                <% } else { %>
                    <div id="conversation-list">
                        <% conversationData.conversations.forEach(function(conv) { %>
                        <a href="/message/<%= conv.targetUser.userName %>" class="conversation-item <%= conv.unreadCount > 0 ? 'has-unread' : '' %> <%= conv.targetUser.id === targetUser.id ? 'active' : '' %>" data-target-user-id="<%= conv.targetUser.id %>">
                            <div class="conversation-avatar">
                                <img src="<%= conv.targetUser.picture %>" alt="<%= conv.targetUser.nickName %>">
                                <% if (conv.unreadCount > 0 && conv.targetUser.id !== targetUser.id) { %>
                                <span class="unread-badge"><%= conv.unreadCount > 99 ? '99+' : conv.unreadCount %></span>
                                <% } %>
                            </div>
                            <div class="conversation-info">
                                <div class="conversation-header">
                                    <span class="conversation-name"><%= conv.targetUser.nickName %></span>
                                    <% if (conv.lastMessage && conv.lastMessageAt) { %>
                                    <span class="conversation-time"><%= formatTime(conv.lastMessageAt) %></span>
                                    <% } %>
                                </div>
                                <div class="conversation-preview">
                                    <% if (conv.lastMessage) { %>
                                        <% if (conv.lastMessage.fromUserId === currentUserId) { %>
                                        <span class="preview-prefix">我：</span>
                                        <% } %>
                                        <span class="preview-content"><%= truncateText(conv.lastMessage.content, 30) %></span>
                                    <% } else { %>
                                        <span class="preview-content text-muted">暂无消息</span>
                                    <% } %>
                                </div>
                            </div>
                        </a>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
        
        <div class="col-8">
            <div class="chat-container">
                <div class="chat-header">
                    <div class="chat-target-info">
                        <img src="<%= targetUser.picture %>" alt="<%= targetUser.nickName %>" class="chat-target-avatar">
                        <div class="chat-target-name"><%= targetUser.nickName %></div>
                    </div>
                </div>
                
                <div class="chat-messages" id="chat-messages">
                    <% if (messageData.isEmpty) { %>
                        <div class="chat-empty-messages">
                            <div class="text-center">
                                <i class="fa fa-comment-o" style="font-size: 48px; color: #ddd; margin-bottom: 15px;"></i>
                                <h5 class="text-muted">还没有消息</h5>
                                <p class="text-muted">发送第一条消息开始聊天</p>
                            </div>
                        </div>
                    <% } else { %>
                        <% messageData.messages.forEach(function(msg) { %>
                        <div class="chat-message <%= msg.isMine ? 'message-mine' : 'message-other' %>" data-message-id="<%= msg.id %>">
                            <% if (!msg.isMine) { %>
                            <img src="<%= msg.fromUser.picture %>" alt="<%= msg.fromUser.nickName %>" class="message-avatar">
                            <% } %>
                            <div class="message-content-wrapper">
                                <% if (!msg.isMine) { %>
                                <div class="message-sender"><%= msg.fromUser.nickName %></div>
                                <% } %>
                                <div class="message-bubble">
                                    <%= msg.content %>
                                </div>
                                <div class="message-time"><%= formatMessageTime(msg.createdAt) %></div>
                            </div>
                            <% if (msg.isMine) { %>
                            <img src="<%= userData.userInfo.picture %>" alt="我" class="message-avatar">
                            <% } %>
                        </div>
                        <% }) %>
                    <% } %>
                </div>
                
                <div class="chat-input-area">
                    <div class="emoji-panel" id="emoji-panel">
                        <div class="emoji-tabs">
                            <span class="emoji-tab active" data-category="emoji">表情</span>
                            <span class="emoji-tab" data-category="gesture">手势</span>
                            <span class="emoji-tab" data-category="animal">动物</span>
                            <span class="emoji-tab" data-category="object">物品</span>
                        </div>
                        <div class="emoji-grid" id="emoji-grid">
                        </div>
                    </div>
                    <div class="chat-input-toolbar">
                        <button type="button" class="toolbar-btn" title="表情" id="emoji-btn">
                            <i class="fa fa-smile-o"></i>
                        </button>
                        <button type="button" class="toolbar-btn" title="图片">
                            <i class="fa fa-image"></i>
                        </button>
                    </div>
                    <div class="chat-input-wrapper">
                        <textarea id="message-input" class="chat-input" placeholder="输入消息..." rows="1"></textarea>
                    </div>
                    <div class="chat-input-footer">
                        <span class="char-count" id="char-count">0/500</span>
                        <button type="button" id="send-btn" class="btn btn-primary btn-sm" disabled>
                            <i class="fa fa-paper-plane"></i> 发送
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<% function formatTime(date) {
    if (!date) return '';
    var d = new Date(date);
    var now = new Date();
    var diff = now - d;
    var oneDay = 24 * 60 * 60 * 1000;
    
    if (diff < 60 * 1000) {
        return '刚刚';
    } else if (diff < 60 * 60 * 1000) {
        return Math.floor(diff / (60 * 1000)) + '分钟前';
    } else if (diff < oneDay && d.getDate() === now.getDate()) {
        var hours = d.getHours();
        var minutes = d.getMinutes();
        return (hours < 10 ? '0' + hours : hours) + ':' + (minutes < 10 ? '0' + minutes : minutes);
    } else if (diff < 2 * oneDay) {
        return '昨天';
    } else {
        var month = d.getMonth() + 1;
        var day = d.getDate();
        return month + '-' + (day < 10 ? '0' + day : day);
    }
} %>

<% function formatMessageTime(date) {
    if (!date) return '';
    var d = new Date(date);
    var hours = d.getHours();
    var minutes = d.getMinutes();
    var month = d.getMonth() + 1;
    var day = d.getDate();
    return month + '-' + (day < 10 ? '0' + day : day) + ' ' + (hours < 10 ? '0' + hours : hours) + ':' + (minutes < 10 ? '0' + minutes : minutes);
} %>

<% function truncateText(text, maxLength) {
    if (!text) return '';
    text = text.replace(/\s+/g, ' ').trim();
    if (text.length <= maxLength) {
        return text;
    }
    return text.substring(0, maxLength) + '...';
} %>

<%- include('layout/footer')%>

