<script>
$(function() {
    function showToast(type, title, message) {
        var icons = {
            success: '✓',
            error: '✕',
            warning: '!'
        };
        
        var toast = $('<div class="toast ' + type + '">' +
            '<div class="toast-icon">' + icons[type] + '</div>' +
            '<div class="toast-content">' +
                '<div class="toast-title">' + title + '</div>' +
                '<div class="toast-message">' + message + '</div>' +
            '</div>' +
            '<button class="toast-close">&times;</button>' +
        '</div>');
        
        $('#toast-container').append(toast);
        
        toast.find('.toast-close').click(function() {
            toast.fadeOut(300, function() {
                toast.remove();
            });
        });
        
        setTimeout(function() {
            toast.fadeOut(300, function() {
                toast.remove();
            });
        }, 3000);
    }

    function validatePasswordStrength(password) {
        var result = {
            length: password.length >= 6,
            number: /\d/.test(password),
            letter: /[a-zA-Z]/.test(password),
            special: /[!@#$%^&*(),.?":{}|<>_\-+=\[\]\\\/~`]/.test(password)
        };
        
        var score = 0;
        if (result.length) score++;
        if (result.number) score++;
        if (result.letter) score++;
        if (result.special) score++;
        
        if (password.length === 0) {
            result.level = 'none';
        } else if (score < 3) {
            result.level = 'weak';
        } else if (score < 4) {
            result.level = 'medium';
        } else {
            result.level = 'strong';
        }
        
        return result;
    }

    function updatePasswordStrength(password) {
        var result = validatePasswordStrength(password);
        
        $('.strength-segment').removeClass('active-weak active-medium active-strong');
        $('#strength-text').removeClass('weak medium strong').text('请输入新密码');
        
        if (result.level === 'none') {
            $('#strength-text').text('请输入新密码');
        } else if (result.level === 'weak') {
            $('#strength-1').addClass('active-weak');
            $('#strength-text').addClass('weak').text('密码强度：弱');
        } else if (result.level === 'medium') {
            $('#strength-1, #strength-2').addClass('active-medium');
            $('#strength-text').addClass('medium').text('密码强度：中');
        } else if (result.level === 'strong') {
            $('#strength-1, #strength-2, #strength-3').addClass('active-strong');
            $('#strength-text').addClass('strong').text('密码强度：强');
        }
        
        $('.requirement-item').each(function() {
            var req = $(this).data('req');
            if (result[req]) {
                $(this).removeClass('invalid').addClass('valid');
                $(this).find('.requirement-icon').text('✓');
            } else {
                $(this).removeClass('valid').addClass('invalid');
                $(this).find('.requirement-icon').text('○');
            }
        });
        
        return result;
    }

    $('.password-toggle').click(function() {
        var targetId = $(this).data('target');
        var $input = $('#' + targetId);
        var $icon = $(this).find('.toggle-icon');
        
        if ($input.attr('type') === 'password') {
            $input.attr('type', 'text');
            $icon.text('🙈');
        } else {
            $input.attr('type', 'password');
            $icon.text('👁️');
        }
    });

    $('#input-new-password').on('input', function() {
        var password = $(this).val();
        updatePasswordStrength(password);
        
        var repeatPassword = $('#input-new-password-repeat').val();
        if (repeatPassword) {
            validateRepeatPassword();
        }
    });

    function validateRepeatPassword() {
        var newPassword = $('#input-new-password').val();
        var repeatPassword = $('#input-new-password-repeat').val();
        var $error = $('#repeat-password-error');
        
        if (repeatPassword && newPassword !== repeatPassword) {
            $error.html('<i class="fa fa-exclamation-circle"></i> 两次密码输入不一致').show();
            $('#input-new-password-repeat').addClass('field-error');
            return false;
        } else {
            $error.hide();
            $('#input-new-password-repeat').removeClass('field-error');
            if (repeatPassword && newPassword === repeatPassword) {
                $('#input-new-password-repeat').addClass('field-success');
            }
            return true;
        }
    }

    $('#input-new-password-repeat').on('input', validateRepeatPassword);

    var $imgPicture = $('#img-picture');
    var $filePicture = $('#file-picture');
    var cropper = null;
    
    $('#avatar-wrapper').click(function() {
        $filePicture.click();
    });
    
    $filePicture.change(function(e) {
        var file = $filePicture[0].files[0];
        if (!file) return;
        
        var reader = new FileReader();
        reader.onload = function(e) {
            var $cropImage = $('#crop-image');
            $cropImage.attr('src', e.target.result);
            
            // 初始化 cropper
            if (cropper) {
                cropper.destroy();
            }
            
            cropper = new Cropper($cropImage[0], {
                aspectRatio: 1,
                viewMode: 1,
                dragMode: 'move',
                autoCropArea: 0.8,
                cropBoxMovable: true,
                cropBoxResizable: true,
                minCropBoxWidth: 100,
                minCropBoxHeight: 100
            });
            
            // 显示模态框
            $('#avatar-crop-modal').modal('show');
        };
        reader.readAsDataURL(file);
    });
    
    // 确认裁剪
    $('#btn-crop-confirm').click(function() {
        if (!cropper) return;
        
        showToast('success', '上传中', '正在上传头像...');
        
        // 获取裁剪后的图片
        cropper.getCroppedCanvas().toBlob(function(blob) {
            var formData = new FormData();
            formData.append('file', blob, 'avatar.jpg');
            
            $.ajax({
                url: '/api/utils/upload',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(data) {
                    if (data.code === 0) {
                        $imgPicture.attr('src', data.data.url);
                        showToast('success', '上传成功', '头像已更新，点击保存按钮生效');
                    } else {
                        showToast('error', '上传失败', data.msg || '上传失败');
                    }
                },
                error: function(err) {
                    showToast('error', '上传失败', err.responseText || '网络错误');
                }
            });
            
            // 隐藏模态框并销毁 cropper
            $('#avatar-crop-modal').modal('hide');
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
        }, 'image/jpeg', 0.8);
    });
    
    // 模态框隐藏时销毁 cropper
    $('#avatar-crop-modal').on('hidden.bs.modal', function() {
        if (cropper) {
            cropper.destroy();
            cropper = null;
        }
    });

    var $imgCover = $('#cover-image');
    var $fileCover = $('#file-cover');
    
    $('#btn-change-cover').click(function() {
        $fileCover.click();
    });
    
    $fileCover.change(function(e) {
        var file = $fileCover[0].files[0];
        if (!file) return;
        
        var reader = new FileReader();
        reader.onload = function(e) {
            showToast('success', '上传中', '正在上传封面...');
            
            ajax.upload('/api/utils/upload', file, function(err, data) {
                if (err) {
                    showToast('error', '上传失败', err.message || err);
                    return;
                }
                $imgCover.attr('src', data.url).show();
                showToast('success', '上传成功', '封面已更新，点击保存按钮生效');
            });
        };
        reader.readAsDataURL(file);
    });

    var $inputNick = $('#input-nick');
    var $nickLoading = $('#nick-loading');
    var $nickStatus = $('#nick-status');
    var $nickMessage = $('#nick-message');
    var nickCheckTimer = null;
    var isNickAvailable = null;

    $inputNick.on('input', function() {
        var value = $(this).val().trim();
        
        $inputNick.removeClass('field-error field-success field-warning');
        $nickStatus.hide();
        $nickMessage.hide();
        isNickAvailable = null;
        
        if (!value) {
            return;
        }
        
        if (nickCheckTimer) {
            clearTimeout(nickCheckTimer);
        }
        
        $nickLoading.show();
        
        nickCheckTimer = setTimeout(function() {
            ajax.post('/api/user/checkNickName', { nickName: value }, function(err, data) {
                $nickLoading.hide();
                
                if (err) {
                    isNickAvailable = false;
                    $inputNick.addClass('field-error');
                    $nickStatus.show().removeClass('success').addClass('error').html('<i class="fa fa-times-circle"></i>');
                    $nickMessage.show().addClass('error-message').html('<i class="fa fa-exclamation-circle"></i> ' + (err.message || err));
                } else {
                    isNickAvailable = true;
                    $inputNick.addClass('field-success');
                    $nickStatus.show().removeClass('error').addClass('success').html('<i class="fa fa-check-circle"></i>');
                    $nickMessage.show().addClass('success-message').html('<i class="fa fa-check-circle"></i> 该昵称可用');
                }
            });
        }, 500);
    });

    $('#info-form').on('submit', function(e) {
        e.preventDefault();
    });

    var $inputSignature = $('#input-signature');
    var $inputBio = $('#input-bio');
    var $inputCity = $('#input-city');
    
    $('#btn-submit-info').on('click', function() {
        try {
            var nickName = $inputNick.val().trim();
            var signature = $inputSignature.val().trim();
            var bio = $inputBio.val().trim();
            var city = $inputCity.val().trim();
            var picture = $imgPicture.attr('src');
            var coverImage = $imgCover.attr('src') || '';

            if (!nickName) {
                showToast('warning', '提示', '请输入昵称');
                $inputNick.addClass('field-error');
                return;
            }

            // 检查昵称是否已通过校验
            if (isNickAvailable === false) {
                showToast('warning', '提示', '昵称已被使用，请换一个试试');
                $inputNick.addClass('field-error');
                return;
            }

            var $btn = $(this);
            var originalText = $btn.text();
            $btn.prop('disabled', true).text('保存中...');

            console.log('提交的参数:', {
                nickName: nickName,
                signature: signature,
                bio: bio,
                city: city,
                picture: picture,
                coverImage: coverImage
            });

            ajax.patch('/api/user/changeInfo', {
                nickName: nickName,
                signature: signature,
                bio: bio,
                city: city,
                picture: picture,
                coverImage: coverImage
            }, function(err, data) {
                console.log('接口响应:', err, data);
                $btn.prop('disabled', false).text(originalText);
                
                if (err) {
                    var errorMsg = err.message || err;
                    if (err.errno === 17001) {
                        $inputNick.addClass('field-error');
                    }
                    showToast('error', '修改失败', errorMsg);
                    return;
                }
                
                showToast('success', '修改成功', '个人信息已更新');
                
                setTimeout(function() {
                    location.href = location.pathname;
                }, 800);
            });
        } catch (ex) {
            console.error(ex);
            showToast('error', '出错了', ex.message);
        }
    });

    $('#password-form').on('submit', function(e) {
        e.preventDefault();
    });

    var $inputCurPassword = $('#input-cur-password');
    var $inputNewPassword = $('#input-new-password');
    var $inputNewPasswordRepeat = $('#input-new-password-repeat');
    
    $('#btn-submit-password').on('click', function() {
        try {
            var curPassword = $inputCurPassword.val();
            var newPassword = $inputNewPassword.val();
            var newPasswordRepeat = $inputNewPasswordRepeat.val();

            $inputCurPassword.removeClass('field-error');
            $inputNewPassword.removeClass('field-error');
            $inputNewPasswordRepeat.removeClass('field-error');
            $('#cur-password-error').hide();
            $('#repeat-password-error').hide();

            var hasError = false;

            if (!curPassword) {
                $('#cur-password-error').html('<i class="fa fa-exclamation-circle"></i> 请输入当前密码').show();
                $inputCurPassword.addClass('field-error');
                hasError = true;
            }

            if (!newPassword) {
                showToast('warning', '提示', '请输入新密码');
                $inputNewPassword.addClass('field-error');
                hasError = true;
            } else {
                var strengthResult = updatePasswordStrength(newPassword);
                if (strengthResult.level !== 'strong') {
                    showToast('warning', '密码强度不足', '密码必须包含数字、字母、特殊符号三种组合');
                    $inputNewPassword.addClass('field-error');
                    hasError = true;
                }
            }

            if (!validateRepeatPassword()) {
                hasError = true;
            }

            if (curPassword === newPassword && newPassword) {
                showToast('warning', '提示', '新密码不能与当前密码相同');
                $inputNewPassword.addClass('field-error');
                hasError = true;
            }

            if (hasError) {
                return;
            }
            
            var $btn = $(this);
            var originalText = $btn.text();
            $btn.prop('disabled', true).text('修改中...');
            
            ajax.patch('/api/user/changePassword', {
                password: curPassword,
                newPassword: newPassword
            }, function(err, data) {
                $btn.prop('disabled', false).text(originalText);
                
                if (err) {
                    if (err.message && err.message.includes('原密码')) {
                        $('#cur-password-error').html('<i class="fa fa-exclamation-circle"></i> ' + err.message).show();
                        $inputCurPassword.addClass('field-error');
                    } else {
                        showToast('error', '修改失败', err.message || err);
                    }
                    return;
                }
                
                showToast('success', '修改成功', '密码已更新，请妥善保管');
                $inputCurPassword.val('');
                $inputNewPassword.val('');
                $inputNewPasswordRepeat.val('');
                updatePasswordStrength('');
                $inputCurPassword.removeClass('field-error field-success');
                $inputNewPassword.removeClass('field-error field-success');
                $inputNewPasswordRepeat.removeClass('field-error field-success');
            });
        } catch (ex) {
            console.error(ex);
            showToast('error', '出错了', ex.message);
        }
    });

    $('#btn-logout').click(function() {
        if (confirm('是否确定退出登录？') === false) {
            return;
        }
        ajax.post('/api/user/logout', function(err, data) {
            if (err) {
                console.error(err);
                return;
            }
            showToast('success', '已退出', '您已成功退出登录');
            setTimeout(function() {
                location.href = '/login';
            }, 1000);
        });
    });

    updatePasswordStrength('');
});
</script>

<%- include('layout/footer')%>
