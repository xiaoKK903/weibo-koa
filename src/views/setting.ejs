<%- include('layout/header', { title: '微博 - 设置', isNav: true })%>

<!-- 引入 cropper.js 库 -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<style>
.cover-image-section {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 12px;
    margin-bottom: 30px;
    overflow: hidden;
}

.cover-image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
}

.cover-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.cover-image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.cover-image-wrapper:hover .cover-image-overlay {
    opacity: 1;
}

.cover-image-btn {
    background: rgba(255, 255, 255, 0.95);
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    cursor: pointer;
    font-weight: 600;
    color: #333;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.cover-image-btn:hover {
    background: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
}

.password-section {
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    border-radius: 12px;
    padding: 30px;
    color: white;
    box-shadow: 0 10px 40px rgba(0, 123, 255, 0.3);
}

.password-section h5 {
    color: white;
    font-size: 1.5rem;
    margin-bottom: 25px;
    font-weight: 600;
}

.password-section .form-group {
    margin-bottom: 20px;
}

.password-section .form-control {
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    padding: 12px 16px;
    font-size: 1rem;
    transition: all 0.3s ease;
}

.password-section .form-control::placeholder {
    color: rgba(255, 255, 255, 0.6);
}

.password-section .form-control:focus {
    background: rgba(255, 255, 255, 0.2);
    border-color: white;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.2);
    outline: none;
}

.password-section .col-form-label {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    padding-top: 12px;
}

.password-strength-wrapper {
    margin-top: 8px;
}

.password-strength-bar {
    display: flex;
    gap: 4px;
    margin-bottom: 8px;
}

.strength-segment {
    flex: 1;
    height: 6px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
    transition: all 0.3s ease;
}

.strength-segment.active-weak {
    background: linear-gradient(90deg, #ff6b6b, #ffa502);
}

.strength-segment.active-medium {
    background: linear-gradient(90deg, #ffa502, #ffd93d);
}

.strength-segment.active-strong {
    background: linear-gradient(90deg, #6bcb77, #4dd599);
}

.password-strength-text {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
}

.password-strength-text.weak {
    color: #ff6b6b;
}

.password-strength-text.medium {
    color: #ffd93d;
}

.password-strength-text.strong {
    color: #6bcb77;
}

.password-requirements {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 15px;
    margin-top: 15px;
}

.password-requirements-title {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 10px;
    color: rgba(255, 255, 255, 0.9);
}

.requirement-item {
    display: flex;
    align-items: center;
    font-size: 0.85rem;
    margin-bottom: 6px;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.3s ease;
}

.requirement-item.valid {
    color: #6bcb77;
}

.requirement-item.invalid {
    color: rgba(255, 255, 255, 0.5);
}

.requirement-icon {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 8px;
    font-size: 0.7rem;
    font-weight: bold;
}

.requirement-item.valid .requirement-icon {
    background: #6bcb77;
    color: white;
}

.requirement-item.invalid .requirement-icon {
    background: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.5);
}

.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.toast {
    background: white;
    border-radius: 10px;
    padding: 16px 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    min-width: 300px;
    opacity: 1;
    animation: slideIn 0.3s ease forwards;
    border-left: 4px solid;
}

@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

.toast.success {
    border-color: #6bcb77;
}

.toast.error {
    border-color: #ff6b6b;
}

.toast.warning {
    border-color: #ffa502;
}

.toast-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    font-size: 1.2rem;
}

.toast.success .toast-icon {
    background: rgba(107, 203, 119, 0.1);
    color: #6bcb77;
}

.toast.error .toast-icon {
    background: rgba(255, 107, 107, 0.1);
    color: #ff6b6b;
}

.toast.warning .toast-icon {
    background: rgba(255, 165, 2, 0.1);
    color: #ffa502;
}

.toast-content {
    flex: 1;
}

.toast-title {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 2px;
}

.toast-message {
    font-size: 0.85rem;
    color: #666;
}

.toast-close {
    background: none;
    border: none;
    font-size: 1.2rem;
    color: #999;
    cursor: pointer;
    padding: 5px;
    line-height: 1;
}

.toast-close:hover {
    color: #666;
}

.password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    font-size: 1rem;
    padding: 5px;
    z-index: 10;
}

.password-toggle:hover {
    color: white;
}

.input-wrapper {
    position: relative;
}

.btn-primary-modern {
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    border: none;
    border-radius: 8px;
    padding: 12px 32px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 123, 255, 0.4);
    color: white;
}

.btn-primary-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 123, 255, 0.5);
}

.btn-primary-modern:active {
