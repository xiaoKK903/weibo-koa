    transition: all 0.3s ease;
}

.repost-input:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

.repost-input::placeholder {
    color: #aaa;
}

.repost-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    padding: 12px 20px;
    border-top: 1px solid #f0f0f0;
}

.btn-repost-cancel {
    padding: 8px 24px;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-repost-cancel:hover {
    background: #f5f5f5;
}

.btn-repost-submit {
    padding: 8px 28px;
    background: #007bff;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    color: #fff;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-repost-submit:hover {
    background: #0056b3;
}

.btn-repost-submit:disabled {
    background: #ccc;
