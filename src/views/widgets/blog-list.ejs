}

.blog-like-btn:hover {
    color: #007bff;
    background-color: rgba(0, 123, 255, 0.1);
    text-decoration: none;
}

.blog-like-btn.liked {
    color: #007bff;
}

.blog-like-btn .like-icon {
    margin-right: 4px;
    transition: all 0.3s ease;
}

.blog-like-btn.liked .like-icon {
    transform: scale(1.1);
}

.like-count {
    font-size: 12px;
    color: #6c757d;
}

/* 评论区域样式 */
.comment-section {
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid #f0f0f0;
}

/* 评论输入框 */
.comment-input-box {
    display: flex;
    gap: 10px;
    margin-bottom: 15px;
}

.comment-input {
    flex: 1;
    min-height: 80px;
    padding: 10px 15px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    resize: vertical;
    font-size: 14px;
    transition: all 0.3s ease;
}

.comment-input:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

.btn-comment-submit {
    align-self: flex-end;
    padding: 8px 20px;
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 123, 255, 0.3);
}

.btn-comment-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 123, 255, 0.4);
}

.btn-comment-submit:disabled {
    background: #ccc;
    cursor: not-allowed;
    box-shadow: none;
    transform: none;
}

/* 评论列表 */
.comment-list-area {
    background: #fafafa;
    border-radius: 8px;
    padding: 10px;
}

.no-comments {
    text-align: center;
    color: #999;
    font-size: 13px;
    padding: 10px;
}

.comment-item {
    display: flex;
    gap: 10px;
    padding: 10px;
    border-bottom: 1px solid #f0f0f0;
    background: white;
    border-radius: 6px;
    margin-bottom: 8px;
}

.comment-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
}

.comment-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
}

.comment-content-wrapper {
    flex: 1;
    min-width: 0;
}

.comment-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 5px;
}

.comment-author {
    font-weight: 600;
    color: #333;
    font-size: 14px;
}

.comment-time {
    font-size: 12px;
    color: #999;
}

.comment-text {
    color: #666;
    font-size: 14px;
    line-height: 1.5;
    word-break: break-word;
}

/* 嵌套评论样式 */
.comment-item.root-comment {
    padding-left: 0;
}

.comment-item.child-comment {
    padding-left: 46px;
    border-left: 2px solid #e9ecef;
    margin-left: 8px;
}

.comment-content {
    flex: 1;
    min-width: 0;
}

.comment-user {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #333;
}

.comment-user a {
    color: #333;
    text-decoration: none;
}

.comment-user a:hover {
    color: #007bff;
}

.comment-reply-to {
    color: #999;
    font-weight: normal;
}

.comment-reply-to a {
    color: #666;
    font-weight: 500;
}

.comment-meta {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 12px;
    color: #999;
}

.comment-actions {
    display: flex;
    gap: 10px;
}

.comment-action-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #999;
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s;
}

.comment-action-btn:hover {
    color: #007bff;
}

.comment-action-btn.liked {
    color: #ff4d4f;
}

.comment-action-btn .count {
    font-weight: 500;
}

/* 回复框样式 */
.reply-form {
    margin-top: 12px;
    padding: 12px;
    background: #f8f9fa;
    border-radius: 8px;
}

.reply-form textarea {
    width: 100%;
    min-height: 60px;
    padding: 10px;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    resize: vertical;
    font-size: 13px;
    transition: all 0.3s ease;
    margin-bottom: 8px;
}

.reply-form textarea:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
}

.reply-form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
}

.reply-form-actions button {
    padding: 6px 16px;
    font-size: 13px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
}

.reply-form-actions .btn-cancel {
    background: #fff;
    border: 1px solid #ddd;
    color: #666;
}

.reply-form-actions .btn-cancel:hover {
    background: #f5f5f5;
}

.reply-form-actions .btn-submit {
    background: #007bff;
    border: none;
    color: white;
}

.reply-form-actions .btn-submit:hover {
    background: #0056b3;
}

/* 子评论展开/收起 */
.children-container {
    margin-top: 8px;
}

.toggle-children-btn {
    background: none;
    border: none;
    padding: 4px 0;
    cursor: pointer;
    color: #007bff;
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

.toggle-children-btn:hover {
    text-decoration: underline;
}

.toggle-children-btn i {
    transition: transform 0.2s;
}

.toggle-children-btn.expanded i {
    transform: rotate(180deg);
}

/* 响应式调整 */
@media (max-width: 768px) {
    .blog-images-container.single-image {
        max-width: 100%;
    }
    
    .blog-images-container.multi-image:has(.blog-image-link:nth-child(2)):not(:has(.blog-image-link:nth-child(3))) {
        max-width: 100%;
    }
    
    .blog-images-container.multi-image:has(.blog-image-link:nth-child(2)):not(:has(.blog-image-link:nth-child(3))) .blog-img {
        height: 120px;
    }
    
    .blog-images-container.multi-image:has(.blog-image-link:nth-child(3)) {
        max-width: 100%;
    }
    
    .blog-images-container.multi-image:has(.blog-image-link:nth-child(3)) .blog-img {
        height: 80px;
    }
    
    .comment-input-box {
        flex-direction: column;
    }
    
    .btn-comment-submit {
        align-self: stretch;
    }
}

.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.toast {
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 10px;
    padding: 16px 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    min-width: 280px;
    transform: translateX(120%);
    opacity: 0;
    transition: all 0.3s ease;
}

.toast.show {
    transform: translateX(0);
    opacity: 1;
}

.toast.success {
    border-color: #6bcb77;
}

.toast.error {
    border-color: #ff6b6b;
}

.toast-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    font-size: 1.2rem;
    font-weight: bold;
}

.toast.success .toast-icon {
    background: rgba(107, 203, 119, 0.1);
    color: #6bcb77;
}

.toast.error .toast-icon {
    background: rgba(255, 107, 107, 0.1);
    color: #ff6b6b;
}

.toast-content {
    flex: 1;
}

.toast-title {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 2px;
}

.toast-message {
    font-size: 0.85rem;
    color: #666;
}

.toast-close {
    background: none;
    border: none;
    font-size: 1.2rem;
    color: #999;
    cursor: pointer;
    padding: 5px;
    line-height: 1;
}

.toast-close:hover {
    color: #666;
}
</style>

<script>
$(function () {
    var currentUserId = parseInt('<%= typeof currentUserId !== "undefined" ? currentUserId : 0 %>');
    var $mainContainer = $('#blog-list-main');
    
    if (!$('#toast-container').length) {
        $('body').append('<div id="toast-container" class="toast-container"></div>');
    }
    
    window.showToast = window.showToast || function(type, title, message) {
        var icons = {
            success: '✓',
            error: '✕',
            warning: '!'
        };
        
        var toast = $('<div class="toast ' + type + '">' +
            '<div class="toast-icon">' + icons[type] + '</div>' +
            '<div class="toast-content">' +
                '<div class="toast-title">' + title + '</div>' +
                '<div class="toast-message">' + (message || '') + '</div>' +
            '</div>' +
            '<button class="toast-close">&times;</button>' +
        '</div>');
        
        $('#toast-container').append(toast);
        
        toast.find('.toast-close').click(function() {
            toast.fadeOut(300, function() {
                toast.remove();
            });
        });
        
        setTimeout(function() {
            toast.addClass('show');
        }, 10);
        
        setTimeout(function() {
            toast.fadeOut(300, function() {
                toast.remove();
            });
        }, 3000);
    };
    
    window.refreshBlogList = function() {
        var pageIndex = 0;
        loadBlogList(pageIndex, true);
    };
    
    function loadBlogList(pageIndex, clear) {
        var url = location.pathname;
        var isSquare = url.indexOf('/square') >= 0;
        
        var apiUrl;
        if (isSquare) {
            apiUrl = '/api/blog/square';
        } else {
            apiUrl = '/api/blog/loadMore/' + pageIndex;
        }
        
        $.ajax({
            url: apiUrl,
            type: 'GET',
            dataType: 'json',
            success: function(res) {
                if (res && res.code === 0 && res.data && res.data.blogList) {
                    var blogList = res.data.blogList;
                    
                    if (clear) {
                        $mainContainer.empty();
                    }
                    
                    blogList.forEach(function(blog) {
                        var html = renderBlogItem(blog);
                        $mainContainer.append(html);
                    });
                    
                    bindBlogEvents();
                }
            },
            error: function() {
                console.error('加载微博列表失败');
            }
        });
    }
    
    function renderBlogItem(blog) {
        var user = blog.user || {};
        var imagesHtml = '';
        
        if (blog.image) {
            var images = blog.image.split(',').filter(function(img) { return img && img.trim(); });
            var imageCount = images.length;
            var containerClass = imageCount > 1 ? 'multi-image' : 'single-image';
            
            imagesHtml = '<div class="blog-images-container ' + containerClass + '">';
            
            images.forEach(function(img, idx) {
                if (idx < 9) {
                    var moreOverlay = '';
                    if (imageCount > 3 && idx === 2) {
                        moreOverlay = '<span class="more-images-overlay">+' + (imageCount - 3) + '</span>';
                    }
                    
                    imagesHtml += '<a href="' + img.trim() + '" target="_blank" class="blog-image-link">';
                    imagesHtml += '<img class="blog-img" src="' + img.trim() + '" />';
                    imagesHtml += moreOverlay;
                    imagesHtml += '</a>';
                }
            });
            
            imagesHtml += '</div>';
        }
        
        var html = '';
        html += '<div class="item-wrapper" data-blog-id="' + blog.id + '">';
        html += '<img class="user-picture" src="' + (user.picture || 'https://dwz.cn/rnTnftZs') + '"/>';
        html += '<div class="content clear-fix blog-content-wrapper">';
        html += imagesHtml;
        html += '<a href="/profile/' + (user.userName || '') + '">';
        html += (user.nickName || user.userName || '用户');
        html += '</a>';
        html += '<span class="blog-user-level-badge" data-user-id="' + user.id + '" style="display: none;">';
        html += '<span class="blog-level-number">L1</span>';
        html += '</span>:';
        html += '<span class="blog-content-summary">' + (blog.contentSummary || '') + '</span>';
        html += '<a href="/detail/' + blog.id + '" class="blog-detail-link">查看全文</a>';
        html += '</div>';
        
        html += '<div class="info">';
        html += '<span>' + (blog.createdAtFormat || '') + '</span>';
        html += '&nbsp;';
        
        if (currentUserId > 0) {
            html += '<a href="#" class="blog-repost-btn"';
            html += ' data-blog-id="' + blog.id + '"';
            html += ' data-user-id="' + blog.userId + '"';
            html += ' data-user-name="' + (user.userName || '') + '"';
            html += ' data-nick-name="' + (user.nickName || '') + '"';
            html += ' data-content="' + (blog.content || '') + '"';
            html += ' data-image="' + (blog.image || '') + '"';
            html += '>';
            html += '<i class="fa fa-retweet"></i> 转发';
            html += '</a>';
            html += '&nbsp;';
            html += '<span class="repost-count" data-blog-id="' + blog.id + '">' + (blog.repostCount || 0) + '</span>';
            html += '&nbsp;';
        }
        
        if (currentUserId > 0) {
            html += '<a href="#" class="blog-list-reply"';
            html += ' data-content="' + (blog.content || '') + '"';
            html += ' data-userName="' + (user.userName || '') + '"';
            html += ' data-nickName="' + (user.nickName || '') + '"';
            html += ' data-blog-id="' + blog.id + '"';
            html += '>';
            html += '<i class="fa fa-comment"></i> 回复';
            html += '</a>';
            html += '&nbsp;';
        }
        
        if (currentUserId > 0) {
            var isCollected = blog.isCollected;
            var collectClass = isCollected ? 'collected' : '';
            var collectIcon = isCollected ? 'fa-star' : 'fa-star-o';
            var collectText = isCollected ? '已收藏' : '收藏';
            
            html += '<a href="#" class="blog-collect-btn ' + collectClass + '"';
            html += ' data-blog-id="' + blog.id + '"';
            html += '>';
            html += '<i class="fa ' + collectIcon + ' collect-icon"></i> <span class="collect-text">' + collectText + '</span>';
            html += '</a>';
            html += '&nbsp;';
            html += '<span class="collect-count" data-blog-id="' + blog.id + '">' + (blog.collectCount || 0) + '</span>';
            html += '&nbsp;';
            
            var isLiked = blog.isLiked;
            var likeClass = isLiked ? 'liked' : '';
            var likeIcon = isLiked ? 'fa-thumbs-up' : 'fa-thumbs-o-up';
            var likeText = isLiked ? '已赞' : '赞';
            
            html += '<a href="#" class="blog-like-btn ' + likeClass + '"';
            html += ' data-blog-id="' + blog.id + '"';
            html += '>';
            html += '<i class="fa ' + likeIcon + ' like-icon"></i> <span class="like-text">' + likeText + '</span>';
            html += '</a>';
            html += '&nbsp;';
            html += '<span class="like-count" data-blog-id="' + blog.id + '">' + (blog.likeCount || 0) + '</span>';
            html += '&nbsp;';
            
            if (currentUserId > 0 && blog.userId !== currentUserId) {
                html += '<a href="#" class="blog-block-btn"';
                html += ' data-user-id="' + blog.userId + '"';
                html += ' data-user-name="' + (blog.user ? blog.user.userName : '') + '"';
                html += ' data-nick-name="' + (blog.user ? blog.user.nickName : '') + '"';
                html += '>';
                html += '<i class="fa fa-ban"></i> 屏蔽';
                html += '</a>';
                html += '&nbsp;';
                html += '<a href="#" class="blog-report-btn"';
                html += ' data-blog-id="' + blog.id + '"';
                html += ' data-target-type="1"';
                html += '>';
                html += '<i class="fa fa-flag"></i> 举报';
                html += '</a>';
                html += '&nbsp;';
            }
            
            if (currentUserId > 0 && blog.userId === currentUserId) {
                html += '<div class="dropdown" style="display: inline-block; margin-right: 10px;">';
                html += '<a href="#" class="blog-visible-type-btn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">';
                html += '<i class="fa fa-eye"></i> 权限';
                html += '</a>';
                html += '<div class="dropdown-menu" aria-labelledby="dropdownMenuButton" style="min-width: 150px;">';
                html += '<a class="dropdown-item" href="#" data-blog-id="' + blog.id + '" data-visible-type="0">' + (blog.visibleType === 0 ? '<i class="fa fa-check"></i> ' : '') + '公开</a>';
                html += '<a class="dropdown-item" href="#" data-blog-id="' + blog.id + '" data-visible-type="1">' + (blog.visibleType === 1 ? '<i class="fa fa-check"></i> ' : '') + '仅自己可见</a>';
                html += '<a class="dropdown-item" href="#" data-blog-id="' + blog.id + '" data-visible-type="2">' + (blog.visibleType === 2 ? '<i class="fa fa-check"></i> ' : '') + '仅粉丝可见</a>';
                html += '</div>';
                html += '</div>';
                html += '<a href="#" class="blog-delete-btn text-danger"';
                html += ' data-blog-id="' + blog.id + '"';
                html += '>';
                html += '<i class="fa fa-trash"></i> 删除';
                html += '</a>';
            }
        }
        
        html += '</div>';
        
        html += '<div class="comment-section" data-blog-id="' + blog.id + '" style="display: none;">';
        html += '<div class="comment-input-box">';
        html += '<textarea class="comment-input" placeholder="写下你的评论..."></textarea>';
        html += '<button class="btn-comment-submit" data-blog-id="' + blog.id + '">发表评论</button>';
        html += '</div>';
        html += '<div class="comment-list-area" data-blog-id="' + blog.id + '">';
        html += '<div class="no-comments">暂无评论</div>';
        html += '</div>';
        html += '</div>';
        
        html += '</div>';
        
        return html;
    }
    
    function bindBlogEvents() {
        $('.blog-list-reply').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var blogId = $(this).data('blog-id');
            var $commentSection = $('.comment-section[data-blog-id="' + blogId + '"]');
            
            if ($commentSection.is(':visible')) {
                $commentSection.hide();
            } else {
                $commentSection.show();
                $commentSection.find('.comment-input').focus();
                loadComments(blogId);
            }
        });
        
        $('.btn-comment-submit').off('click').on('click', function(e) {
            e.preventDefault();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var $input = $btn.closest('.comment-input-box').find('.comment-input');
            var content = $input.val().trim();
            
            if (!content) {
                alert('请输入评论内容');
                return;
            }
            
            $btn.prop('disabled', true);
            
            ajax.post('/api/blog/comment', {
                blogId: blogId,
                content: content
            }, function(err) {
                $btn.prop('disabled', false);
                
                if (err) {
                    var errorMsg = err.message || err;
                    alert(errorMsg);
                    return;
                }
                
                $input.val('');
                loadComments(blogId, true);
            });
        });
        
        $('.blog-collect-btn').off('click').on('click', function(e) {
            e.preventDefault();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var isCollected = $btn.hasClass('collected');
            var url = isCollected ? '/api/blog/uncollect' : '/api/blog/collect';
            
            ajax.post(url, { blogId: blogId }, function(err) {
                if (err) {
                    var errorMsg = err.message || err;
                    alert(errorMsg);
                    return;
                }
                
                var $countSpan = $('.collect-count[data-blog-id="' + blogId + '"]');
                var currentCount = parseInt($countSpan.text()) || 0;
                
                if (isCollected) {
                    $btn.removeClass('collected');
                    $btn.find('.collect-icon').removeClass('fa-star').addClass('fa-star-o');
                    $btn.find('.collect-text').text('收藏');
                    $countSpan.text(currentCount - 1);
                } else {
                    $btn.addClass('collected');
                    $btn.find('.collect-icon').removeClass('fa-star-o').addClass('fa-star');
                    $btn.find('.collect-text').text('已收藏');
                    $countSpan.text(currentCount + 1);
                }
            });
        });
        
        $('.blog-like-btn').off('click').on('click', function(e) {
            e.preventDefault();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var isLiked = $btn.hasClass('liked');
            var url = isLiked ? '/api/blog/unlike' : '/api/blog/like';
            
            ajax.post(url, { blogId: blogId }, function(err) {
                if (err) {
                    var errorMsg = err.message || err;
                    alert(errorMsg);
                    return;
                }
                
                var $countSpan = $('.like-count[data-blog-id="' + blogId + '"]');
                var currentCount = parseInt($countSpan.text()) || 0;
                
                if (isLiked) {
                    $btn.removeClass('liked');
                    $btn.find('.like-icon').removeClass('fa-thumbs-up').addClass('fa-thumbs-o-up');
                    $btn.find('.like-text').text('赞');
                    $countSpan.text(currentCount - 1);
                } else {
                    $btn.addClass('liked');
                    $btn.find('.like-icon').removeClass('fa-thumbs-o-up').addClass('fa-thumbs-up');
                    $btn.find('.like-text').text('已赞');
                    $countSpan.text(currentCount + 1);
                }
            });
        });
        
        $('.blog-delete-btn').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var $item = $btn.closest('.item-wrapper');
            
            $btn.prop('disabled', true);
            
            ajax.post('/api/blog/delete', { blogId: blogId }, function(err) {
                if (err) {
                    var errorMsg = err.message || err;
                    window.showToast('error', '删除失败', errorMsg);
                    $btn.prop('disabled', false);
                    return;
                }
                
                window.showToast('success', '删除成功', '微博已移入回收站');
                
                $item.fadeOut(300, function() {
                    $(this).remove();
                });
            });
        });
        
        $('.dropdown-menu a[data-visible-type]').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var visibleType = $btn.data('visible-type');
            var visibleTypeName = $btn.text();
            
            ajax.post('/api/blog/update-visible-type', { blogId: blogId, visibleType: visibleType }, function(err) {
                if (err) {
                    var errorMsg = err.message || err;
                    window.showToast('error', '修改失败', errorMsg);
                    return;
                }
                
                window.showToast('success', '修改成功', '微博权限已修改为' + visibleTypeName);
            });
        });
        
        $(document).off('click', '.btn-reply').on('click', '.btn-reply', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var $commentItem = $(this).closest('.comment-item');
            var $replyForm = $commentItem.find('.reply-form').first();
            
            $('.reply-form').not($replyForm).hide();
            
            $replyForm.toggle();
            if ($replyForm.is(':visible')) {
                $replyForm.find('textarea').focus();
            }
        });
        
        $(document).off('click', '.reply-form .btn-cancel').on('click', '.reply-form .btn-cancel', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var $replyForm = $(this).closest('.reply-form');
            $replyForm.find('textarea').val('');
            $replyForm.hide();
        });
        
        $(document).off('click', '.btn-submit-reply').on('click', '.btn-submit-reply', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var $btn = $(this);
            var $replyForm = $btn.closest('.reply-form');
            var content = $replyForm.find('textarea').val().trim();
            var parentId = $btn.data('parent-id');
            var replyUserId = $btn.data('reply-user-id');
            var blogId = $btn.data('blog-id');
            
            if (!content) {
                alert('请输入回复内容');
                return;
            }
            
            $btn.prop('disabled', true);
            
            ajax.post('/api/blog/comment/create', {
                blogId: Number(blogId),
                content: content,
                parentId: Number(parentId),
                replyUserId: Number(replyUserId)
            }, function(err, data) {
                $btn.prop('disabled', false);
                
                if (err) {
                    var errorMsg = err.message || err;
                    alert(errorMsg);
                    return;
                }
                
                $replyForm.find('textarea').val('');
                $replyForm.hide();
                loadComments(blogId, true);
            });
        });
        
        $(document).off('click', '.toggle-children-btn').on('click', '.toggle-children-btn', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var $btn = $(this);
            var commentId = $btn.data('comment-id');
            var $commentItem = $btn.closest('.comment-item');
            var $childrenList = $commentItem.find('.children-list[data-parent-id="' + commentId + '"]');
            var isExpanded = $btn.hasClass('expanded');
            
            if (isExpanded) {
                $childrenList.slideUp(200);
                $btn.removeClass('expanded');
                var childCount = $childrenList.find('.comment-item').length;
                $btn.find('.toggle-text').text('展开 ' + childCount + ' 条回复');
            } else {
                $childrenList.slideDown(200);
                $btn.addClass('expanded');
                $btn.find('.toggle-text').text('收起回复');
            }
        });
        
        $(document).off('click', '.btn-like-comment').on('click', '.btn-like-comment', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var $btn = $(this);
            var commentId = $btn.data('comment-id');
            var blogId = $btn.data('blog-id');
            var isLiked = $btn.hasClass('liked');
            
            var url = isLiked ? '/api/blog/comment/unlike' : '/api/blog/comment/like';
            
            ajax.post(url, { commentId: Number(commentId) }, function(err) {
                if (err) {
                    var errorMsg = err.message || err;
                    alert(errorMsg);
                    return;
                }
                
                var $countSpan = $btn.find('.count');
                var count = parseInt($countSpan.text()) || 0;
                
                if (isLiked) {
                    $btn.removeClass('liked');
                    $btn.find('i').removeClass('fa-heart').addClass('fa-heart-o');
                    $countSpan.text(Math.max(0, count - 1));
                } else {
                    $btn.addClass('liked');
                    $btn.find('i').removeClass('fa-heart-o').addClass('fa-heart');
                    $countSpan.text(count + 1);
                }
            });
        });
        
        $(document).off('click', '.btn-delete-comment').on('click', '.btn-delete-comment', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var commentId = $(this).data('comment-id');
            var blogId = $(this).data('blog-id');
            var $btn = $(this);
            
            $btn.prop('disabled', true);
            
            ajax.post('/api/blog/comment/delete', { commentId: Number(commentId) }, function(err) {
                if (err) {
                    var errorMsg = err.message || err;
                    window.showToast('error', '删除失败', errorMsg);
                    $btn.prop('disabled', false);
                    return;
                }
                
                window.showToast('success', '删除成功', '评论已删除');
                loadComments(blogId);
            });
        });
        
        // 微博屏蔽按钮点击事件
        $('.blog-block-btn').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var $btn = $(this);
            var userId = $btn.data('user-id');
            var nickName = $btn.data('nick-name') || '该用户';
            
            if (confirm('确定要屏蔽 ' + nickName + ' 吗？屏蔽后将不再看到对方的微博、评论和@提醒。')) {
                ajax.post('/api/block/create', {
                    blockedId: userId
                }, function(err, data) {
                    if (err) {
                        alert(err);
                        return;
                    }
                    alert('已屏蔽 ' + nickName);
                    // 刷新页面或移除该微博
                    $btn.closest('.item-wrapper').fadeOut(300, function() {
                        $(this).remove();
                    });
                });
            }
        });
        
        // 微博举报按钮点击事件
        $('.blog-report-btn').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var targetType = $btn.data('target-type');
            
            openReportModal(blogId, targetType, null);
        });
        
        // 评论举报按钮点击事件
        $(document).off('click', '.btn-report-comment').on('click', '.btn-report-comment', function(e) {
            e.stopPropagation();
            e.preventDefault();
            var $btn = $(this);
            var commentId = $btn.data('comment-id');
            var blogId = $btn.data('blog-id');
            var targetType = $btn.data('target-type');
            
            openReportModal(blogId, targetType, commentId);
        });
        
        // 微博转发按钮点击事件
        $('.blog-repost-btn').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var userId = $btn.data('user-id');
            var userName = $btn.data('user-name');
            var nickName = $btn.data('nick-name');
            var content = $btn.data('content');
            var image = $btn.data('image');
            
            openRepostModal(blogId, userId, userName, nickName, content, image);
        });
    }
    
    // 打开举报弹窗
    function openReportModal(blogId, targetType, commentId) {
        // 创建弹窗HTML
        var modalHtml = '<div id="report-modal" class="report-modal" style="display: block;">';
        modalHtml += '<div class="report-modal-overlay"></div>';
        modalHtml += '<div class="report-modal-content">';
        modalHtml += '<div class="report-modal-header">';
        modalHtml += '<h3>举报</h3>';
        modalHtml += '<button class="report-modal-close">&times;</button>';
        modalHtml += '</div>';
        modalHtml += '<div class="report-modal-body">';
        modalHtml += '<div class="report-type-container">';
        modalHtml += '<h4>请选择举报类型：</h4>';
        modalHtml += '<div class="report-type-list">';
        modalHtml += '<label class="report-type-item">';
        modalHtml += '<input type="radio" name="reportType" value="1">';
        modalHtml += '<span>色情</span>';
        modalHtml += '</label>';
        modalHtml += '<label class="report-type-item">';
        modalHtml += '<input type="radio" name="reportType" value="2">';
        modalHtml += '<span>暴力</span>';
        modalHtml += '</label>';
        modalHtml += '<label class="report-type-item">';
        modalHtml += '<input type="radio" name="reportType" value="3">';
        modalHtml += '<span>违法</span>';
        modalHtml += '</label>';
        modalHtml += '<label class="report-type-item">';
        modalHtml += '<input type="radio" name="reportType" value="4">';
        modalHtml += '<span>广告</span>';
        modalHtml += '</label>';
        modalHtml += '<label class="report-type-item">';
        modalHtml += '<input type="radio" name="reportType" value="5">';
        modalHtml += '<span>其他</span>';
        modalHtml += '</label>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        modalHtml += '<div class="report-content-container">';
        modalHtml += '<h4>补充说明（可选）：</h4>';
        modalHtml += '<textarea class="report-content" placeholder="请输入详细的举报说明..."></textarea>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        modalHtml += '<div class="report-modal-footer">';
        modalHtml += '<button class="btn-report-cancel">取消</button>';
        modalHtml += '<button class="btn-report-submit" data-blog-id="' + blogId + '" data-target-type="' + targetType + '" data-comment-id="' + (commentId || '') + '">提交举报</button>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        
        // 添加到页面
        $('body').append(modalHtml);
        
        // 绑定事件
        bindReportModalEvents();
    }
    
    // 绑定举报弹窗事件
    function bindReportModalEvents() {
        // 关闭按钮
        $('.report-modal-close, .report-modal-overlay, .btn-report-cancel').off('click').on('click', function() {
            closeReportModal();
        });
        
        // 提交举报
        $('.btn-report-submit').off('click').on('click', function() {
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var targetType = $btn.data('target-type');
            var commentId = $btn.data('comment-id');
            var reportType = $('input[name="reportType"]:checked').val();
            var content = $('.report-content').val().trim();
            
            // 验证举报类型
            if (!reportType) {
                window.showToast('warning', '提示', '请选择举报类型');
                return;
            }
            
            // 禁用提交按钮
            $btn.prop('disabled', true);
            $btn.text('提交中...');
            
            // 准备提交数据
            var submitData = {
                targetType: parseInt(targetType),
                reportType: parseInt(reportType),
                content: content
            };
            
            // 根据目标类型设置targetId
            if (targetType === 1) { // 微博
                submitData.targetId = parseInt(blogId);
            } else if (targetType === 2) { // 评论
                submitData.targetId = parseInt(commentId);
            }
            
            // 提交举报
            ajax.post('/api/report/create', submitData, function(err) {
                // 恢复按钮状态
                $btn.prop('disabled', false);
                $btn.text('提交举报');
                
                if (err) {
                    var errorMsg = err.message || err;
                    window.showToast('error', '举报失败', errorMsg);
                    return;
                }
                
                window.showToast('success', '举报成功', '您的举报已提交，我们将尽快处理');
                closeReportModal();
            });
        });
    }
    
    // 关闭举报弹窗
    function closeReportModal() {
        $('#report-modal').remove();
    }
    
    // 打开转发弹窗
    function openRepostModal(blogId, userId, userName, nickName, content, image) {
        var modalHtml = '<div id="repost-modal" class="repost-modal" style="display: block;">';
        modalHtml += '<div class="repost-modal-overlay"></div>';
        modalHtml += '<div class="repost-modal-content">';
        modalHtml += '<div class="repost-modal-header">';
        modalHtml += '<h3>转发微博</h3>';
        modalHtml += '<button class="repost-modal-close">&times;</button>';
        modalHtml += '</div>';
        modalHtml += '<div class="repost-modal-body">';
        modalHtml += '<div class="repost-source-info">';
        modalHtml += '<div class="repost-source-user">';
        modalHtml += '<span class="repost-source-nickname">@' + (nickName || userName) + '</span>';
        modalHtml += '</div>';
        modalHtml += '<div class="repost-source-content">' + content + '</div>';
        if (image) {
            modalHtml += '<div class="repost-source-image"><img src="' + image + '" alt="配图" /></div>';
        }
        modalHtml += '</div>';
        modalHtml += '<div class="repost-input-container">';
        modalHtml += '<textarea class="repost-input" placeholder="说点什么..."></textarea>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        modalHtml += '<div class="repost-modal-footer">';
        modalHtml += '<button class="btn-repost-cancel">取消</button>';
        modalHtml += '<button class="btn-repost-submit" data-blog-id="' + blogId + '">转发</button>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        modalHtml += '</div>';
        
        $('body').append(modalHtml);
        $('.repost-input').focus();
        
        bindRepostModalEvents();
    }
    
    // 绑定转发弹窗事件
    function bindRepostModalEvents() {
        $('.repost-modal-close, .repost-modal-overlay, .btn-repost-cancel').off('click').on('click', function() {
            closeRepostModal();
        });
        
        $('.btn-repost-submit').off('click').on('click', function() {
            var $btn = $(this);
            var blogId = $btn.data('blog-id');
            var content = $('.repost-input').val().trim();
            
            $btn.prop('disabled', true);
            $btn.text('转发中...');
            
            ajax.post('/api/repost/create', {
                sourceBlogId: blogId,
                content: content
            }, function(err, data) {
                $btn.prop('disabled', false);
                $btn.text('转发');
                
                if (err) {
                    var errorMsg = err.message || err;
                    window.showToast('error', '转发失败', errorMsg);
                    return;
                }
                
                window.showToast('success', '转发成功', '微博已转发');
                
                var $countSpan = $('.repost-count[data-blog-id="' + blogId + '"]');
                var currentCount = parseInt($countSpan.text()) || 0;
                $countSpan.text(currentCount + 1);
                
                if (data && data.blog) {
                    var newBlogHtml = renderBlogItem(data.blog);
                    var $blogList = $('.weibo-list');
                    
                    if ($blogList.length > 0) {
                        $blogList.prepend(newBlogHtml);
                        
                        var $newItem = $blogList.find('.item-wrapper:first');
                        $newItem.hide().fadeIn(300);
                        
                        bindBlogEvents();
                    }
                }
                
                closeRepostModal();
            });
        });
    }
    
    // 关闭转发弹窗
    function closeRepostModal() {
        $('#repost-modal').remove();
    }
    
    function renderCommentItem(comment, level, blogId) {
        var isRoot = level === 0;
        var hasChildren = comment.children && comment.children.length > 0;
        var isLikedByCurrentUser = comment.isLiked;
        var likeIcon = isLikedByCurrentUser ? 'fa-heart' : 'fa-heart-o';
        var likeClass = isLikedByCurrentUser ? 'liked' : '';
        var user = comment.user || {};
        var replyUser = comment.replyUser || null;
        
        var replyToHtml = '';
        if (replyUser) {
            replyToHtml = '<span class="comment-reply-to"> 回复 <a href="/profile/' + replyUser.userName + '">' + replyUser.nickName + '</a></span>';
        }
        
        var deleteBtn = '';
        if (currentUserId && currentUserId === user.id) {
            deleteBtn = '<button class="comment-action-btn btn-delete-comment" data-comment-id="' + comment.id + '" data-blog-id="' + blogId + '"><i class="fa fa-trash"></i> 删除</button>';
        }
        
        var reportBtn = '';
        if (currentUserId && currentUserId !== user.id) {
            reportBtn = '<button class="comment-action-btn btn-report-comment" data-comment-id="' + comment.id + '" data-blog-id="' + blogId + '" data-target-type="2"><i class="fa fa-flag"></i> 举报</button>';
        }
        
        var html = '';
        html += '<div class="comment-item ' + (isRoot ? 'root-comment' : 'child-comment') + '" data-comment-id="' + comment.id + '" data-root-id="' + (comment.rootId || comment.id) + '">';
        html += '<img src="' + (user.picture || 'https://dwz.cn/rnTnftZs') + '" alt="' + (user.nickName || '用户') + '" class="comment-avatar">';
        html += '<div class="comment-content">';
        html += '<div class="comment-user">';
        html += '<a href="/profile/' + (user.userName || '') + '">' + (user.nickName || user.userName || '用户') + '</a>';
        html += replyToHtml;
        html += '</div>';
        html += '<div class="comment-text">' + (comment.content || '') + '</div>';
        html += '<div class="comment-meta">';
        html += '<span class="comment-time">' + (comment.createdAtFormat || '') + '</span>';
        html += '<div class="comment-actions">';
        html += '<button class="comment-action-btn btn-reply" data-comment-id="' + comment.id + '" data-reply-user-id="' + user.id + '" data-reply-user-name="' + (user.nickName || '用户') + '" data-blog-id="' + blogId + '">';
        html += '<i class="fa fa-reply"></i> 回复';
        html += '</button>';
        html += '<button class="comment-action-btn btn-like-comment ' + likeClass + '" data-comment-id="' + comment.id + '" data-blog-id="' + blogId + '">';
        html += '<i class="fa ' + likeIcon + '"></i> <span class="count">' + (comment.likeCount || 0) + '</span>';
        html += '</button>';
        html += deleteBtn;
        html += reportBtn;
        html += '</div>';
        html += '</div>';
        
        html += '<div class="reply-form" style="display: none;">';
        html += '<textarea class="reply-textarea" placeholder="回复 @' + (user.nickName || '用户') + '..."></textarea>';
        html += '<div class="reply-form-actions">';
        html += '<button class="btn-cancel">取消</button>';
        html += '<button class="btn-submit btn-submit-reply" data-parent-id="' + comment.id + '" data-reply-user-id="' + user.id + '" data-blog-id="' + blogId + '">回复</button>';
        html += '</div>';
        html += '</div>';
        
        if (hasChildren) {
            html += '<div class="children-container">';
            html += '<button class="toggle-children-btn" data-comment-id="' + comment.id + '">';
            html += '<i class="fa fa-chevron-down"></i>';
            html += '<span class="toggle-text">展开 ' + comment.children.length + ' 条回复</span>';
            html += '</button>';
            html += '<div class="children-list" style="display: none;" data-parent-id="' + comment.id + '">';
            comment.children.forEach(function(child) {
                html += renderCommentItem(child, level + 1, blogId);
            });
            html += '</div>';
            html += '</div>';
        }
        
        html += '</div>';
        html += '</div>';
        
        return html;
    }

    function renderComments(comments, blogId) {
        var $listArea = $('.comment-list-area[data-blog-id="' + blogId + '"]').first();
        
        if (!$listArea.length) {
            return;
        }
        
        if (!comments || comments.length === 0) {
            $listArea.html('<div class="no-comments">暂无评论</div>');
            return;
        }
        
        var html = '';
        comments.forEach(function(comment) {
            html += renderCommentItem(comment, 0, blogId);
        });
        
        $listArea.html(html);
    }

    function loadComments(blogId, autoExpand) {
        ajax.get('/api/blog/comment/' + blogId, {}, function(err, data) {
            if (err) {
                console.error(err);
                return;
            }
            
            var comments = (data && data.commentList) || [];
            
            var $listArea = $('.comment-list-area[data-blog-id="' + blogId + '"]').first();
            if (!$listArea.length) {
                return;
            }
            
            renderComments(comments, blogId);
            
            if (autoExpand) {
                $listArea.find('.toggle-children-btn').each(function() {
                    var $btn = $(this);
                    var commentId = $btn.data('comment-id');
                    var $childrenList = $btn.siblings('.children-list[data-parent-id="' + commentId + '"]');
                    
                    if ($childrenList.length) {
                        $childrenList.show();
                        $btn.addClass('expanded');
                        $btn.find('.toggle-text').text('收起回复');
                    }
                });
            }
        });
    }
    
    bindBlogEvents();
    loadUserLevelBadges();
});

function loadUserLevelBadges() {
    var $badges = $('.blog-user-level-badge:visible');
    var userIds = [];
    var userIdMap = {};
    
    $badges.each(function() {
        var userId = $(this).data('user-id');
        if (userId && !userIdMap[userId]) {
            userIdMap[userId] = true;
            userIds.push(userId);
        }
    });
    
    if (userIds.length === 0) {
        return;
    }
    
    userIds.forEach(function(userId) {
        $.ajax({
            url: '/api/point/level/' + userId,
            type: 'GET',
            dataType: 'json',
            success: function(res) {
                if (res && res.code === 0 && res.data) {
                    var levelInfo = res.data;
                    var level = levelInfo.level || 1;
                    var badgeColor = levelInfo.badgeColor || '#808080';
                    
                    $('.blog-user-level-badge[data-user-id="' + userId + '"]').each(function() {
                        var $badge = $(this);
                        $badge.find('.blog-level-number').text('L' + level);
                        $badge.css('background', 'linear-gradient(135deg, ' + badgeColor + ' 0%, ' + adjustColor(badgeColor, -20) + ' 100%)');
                        $badge.show();
                    });
                }
            },
            error: function() {
                $('.blog-user-level-badge[data-user-id="' + userId + '"]').show();
            }
        });
    });
}

function adjustColor(hex, amount) {
    var num = parseInt(hex.replace('#', ''), 16);
    var r = (num >> 16) + amount;
    var g = ((num >> 8) & 0x00FF) + amount;
    var b = (num & 0x0000FF) + amount;
    r = Math.min(255, Math.max(0, r));
    g = Math.min(255, Math.max(0, g));
    b = Math.min(255, Math.max(0, b));
    return '#' + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
}
</script>
