    color: #333;
}

.repost-modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #999;
    cursor: pointer;
    padding: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.repost-modal-close:hover {
    color: #333;
}

.repost-modal-body {
    padding: 16px 20px;
}

.repost-source-info {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 16px;
    border-left: 3px solid #007bff;
}

.repost-source-user {
    margin-bottom: 8px;
}

.repost-source-nickname {
    font-weight: bold;
    color: #007bff;
    font-size: 14px;
}

.repost-source-content {
    font-size: 14px;
    line-height: 1.6;
    color: #333;
    max-height: 150px;
    overflow-y: auto;
    word-break: break-all;
}

.repost-source-image {
    margin-top: 10px;
}

.repost-source-image img {
    max-width: 100%;
    max-height: 200px;
    border-radius: 6px;
    object-fit: cover;
}

.repost-input-container {
    position: relative;
}

.repost-input {
    width: 100%;
    min-height: 80px;
    padding: 12px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 14px;
