<% if (hotTopics && hotTopics.length > 0) { %>
<div class="right-item">
    <div class="right-item-title">
        <i class="fa fa-fire"></i> 热门话题
    </div>
    <div class="hot-topics-list">
        <% hotTopics.forEach((topic, index) => { %>
        <div class="hot-topic-item">
            <div class="hot-topic-rank">
                <% if (index < 3) { %>
                <span class="rank-top"><%= index + 1 %></span>
                <% } else { %>
                <span class="rank-normal"><%= index + 1 %></span>
                <% } %>
            </div>
            <div class="hot-topic-content">
                <a href="/topic/<%= encodeURIComponent(topic.name) %>" class="hot-topic-link">#<%= topic.name %>#</a>
                <div class="hot-topic-meta">
                    <span class="hot-topic-count"><%= topic.blogCount %> 条动态</span>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>
<% } %>

<style>
/* 热门话题样式 */
.hot-topics-list {
    padding: 10px 0;
}

.hot-topic-item {
    display: flex;
    padding: 10px 0;
    border-bottom: 1px solid #f1f1f1;
}

.hot-topic-item:last-child {
    border-bottom: none;
}

.hot-topic-rank {
    width: 30px;
    text-align: center;
    margin-right: 10px;
}

.hot-topic-content {
    flex: 1;
}

.hot-topic-link {
    display: block;
    color: #007bff;
    font-size: 14px;
    line-height: 1.4;
    margin-bottom: 5px;
    text-decoration: none;
    transition: color 0.3s ease;
}

.hot-topic-link:hover {
    color: #0056b3;
    text-decoration: underline;
}

.hot-topic-meta {
    font-size: 12px;
    color: #999;
}

.hot-topic-count {
    margin-right: 10px;
}
</style>
