<!-- 微博输入框 -->
<div class="margin-bottom-10 padding-bottom-10 border-bottom">
    <div id="editor-container" style="min-height: 120px;"></div>
    <div class="margin-top-10">
        <button class="btn btn-primary btn-modern" id="btn-submit">发表</button>
        &nbsp;
        <a href="#" id="btn-add-img" class="btn btn-outline-secondary btn-upload">
            <i class="fa fa-picture-o"></i>
            插入图片
        </a>
        <input type="file" accept="image/*" id="file-picture" style="display: none;">
        <span id="span-img-name" class="img-upload-status"></span>
    </div>
</div>

<style>
/* 编辑器样式 */
#editor-container {
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    transition: all 0.3s ease;
}

#editor-container:focus-within {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.ql-container {
    font-size: 14px;
    border: none !important;
    min-height: 120px;
}

.ql-editor {
    min-height: 120px;
    padding: 12px 16px;
}

.ql-editor:focus {
    outline: none;
}

/* 按钮样式 */
.btn-modern {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    border-radius: 8px;
    padding: 10px 24px;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    color: white;
}

.btn-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
    color: white;
}

.btn-modern:active {
    transform: translateY(0);
}

.btn-upload {
    border: 2px solid #667eea;
    color: #667eea;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 500;
    transition: all 0.3s ease;
}

.btn-upload:hover {
    background: #667eea;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

/* 图片上传状态 */
.img-upload-status {
    font-size: 12px;
    color: #666;
    margin-left: 10px;
    padding: 4px 8px;
    background: #f8f9fa;
    border-radius: 4px;
    transition: all 0.3s ease;
}

/* 自定义工具栏 */
.ql-toolbar.ql-snow {
    border: none !important;
    border-bottom: 2px solid #f1f1f1 !important;
    border-radius: 8px 8px 0 0;
    padding: 8px 12px;
    background: #f8f9fa;
}

.ql-toolbar.ql-snow .ql-formats {
    margin-right: 12px;
}

.ql-toolbar.ql-snow button {
    transition: all 0.3s ease;
    border-radius: 4px;
}

.ql-toolbar.ql-snow button:hover {
    background: #e0e0e0;
}

.ql-toolbar.ql-snow button.ql-active {
    background: #667eea;
    color: white;
}

/* 响应式调整 */
@media (max-width: 768px) {
    .btn-modern,
    .btn-upload {
        padding: 8px 16px;
        font-size: 13px;
    }
}
</style>

<script>
$(function () {
    var $spanImgName = $('#span-img-name')
    var $filePicture = $('#file-picture')
    
    // 初始化 Quill 编辑器
    var quill = new Quill('#editor-container', {
        theme: 'snow',
        placeholder: '分享你的想法...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline', 'strike'],        // 加粗、斜体、下划线、删除线
                ['blockquote', 'code-block'],                    // 引用、代码块
                [{ 'header': 1 }, { 'header': 2 }],              // 标题1、标题2
                [{ 'list': 'ordered' }, { 'list': 'bullet' }],   // 有序列表、无序列表
                [{ 'color': [] }, { 'background': [] }],         // 文本颜色、背景颜色
                ['clean']                                        // 清除格式
            ]
        }
    });

    // 上传图片
    $filePicture.change(function (e) {
        var file = $filePicture[0].files[0]
        if (!file) return;
        
        $spanImgName.text('上传中...').css({ 'color': '#667eea', 'background': 'rgba(102, 126, 234, 0.1)' });
        
        ajax.upload('/api/utils/upload', file, function(err, data) {
            if (err) {
                $spanImgName.text('上传失败').css({ 'color': '#ff6b6b', 'background': 'rgba(255, 107, 107, 0.1)' });
                return
            }
            
            // 成功 - 在编辑器中插入图片
            var range = quill.getSelection();
            if (range) {
                quill.insertEmbed(range.index, 'image', data.url);
                quill.setSelection(range.index + 1);
            } else {
                quill.insertEmbed(0, 'image', data.url);
            }
            
            $spanImgName.text('上传成功').css({ 'color': '#6bcb77', 'background': 'rgba(107, 203, 119, 0.1)' });
            
            // 3秒后清除提示
            setTimeout(function() {
                $spanImgName.text('');
            }, 3000);
        })
    })

    // 插入图片
    $('#btn-add-img').click(function (e) {
        e.preventDefault()
        //  开始选择图片
        $filePicture.click()
    })

    // 发布微博
    $('#btn-submit').click(function () {
        // 从编辑器获取 HTML 内容
        var content = quill.root.innerHTML.trim()
        
        // 验证
        if (content.length === 0) {
            alert('请输入微博内容')
            return
        }

        // 发布
        ajax.post('/api/blog/create', {
            content: content,
            image: '' // 富文本编辑器中已包含图片，不需要单独的 image 字段
        }, function (err) {
            if (err) {
                // 失败
                alert(err)
                return
            }
            // 成功
            $filePicture.val('')
            $spanImgName.text('')
            quill.setText('') // 清空编辑器

            // 刷新页面
            location.href = location.pathname
        })
    })

    // @ 功能 - 暂时禁用，因为需要 Quill 插件支持
    // 后续可以使用 quill-mention 插件实现
});
</script>
