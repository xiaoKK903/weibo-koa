<script>
(function() {
    var overlayId = 'global-level-rules-overlay';
    var closeBtnId = 'global-close-level-rules';
    var initialized = false;
    
    function init() {
        if (initialized) return;
        initialized = true;
        
        var $overlay = $('#' + overlayId);
        
        $(document).on('click', '#show-level-rules', function(e) {
            e.preventDefault();
            e.stopPropagation();
            $overlay.addClass('show');
        });
        
        $(document).on('click', '#' + closeBtnId, function(e) {
            e.preventDefault();
            e.stopPropagation();
            $overlay.removeClass('show');
        });
        
        $overlay.on('click', function(e) {
            if (e.target === this) {
                $(this).removeClass('show');
            }
        });
    }
    
    if (window.jQuery) {
        init();
    } else {
        $(document).ready(init);
    }
})();
</script>