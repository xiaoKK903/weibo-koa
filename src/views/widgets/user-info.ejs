}

.level-rules-section:last-child {
    margin-bottom: 0;
}

.level-rules-section-title {
    font-size: 14px;
    font-weight: 600;
    color: #333;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.level-rules-section-title i {
    color: #667eea;
}

.level-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

.level-table th {
    background: #f8f9fa;
    padding: 10px 12px;
    text-align: left;
    font-weight: 600;
    color: #333;
    border-bottom: 2px solid #e9ecef;
}

.level-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #f0f0f0;
}

.level-table tr:last-child td {
    border-bottom: none;
}

.level-badge-small {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
    color: white;
}

.points-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

.points-table th {
    background: #f8f9fa;
    padding: 10px 12px;
    text-align: left;
    font-weight: 600;
    color: #333;
    border-bottom: 2px solid #e9ecef;
}

.points-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #f0f0f0;
}

.points-table tr:last-child td {
    border-bottom: none;
}

.points-table .exp-plus {
    color: #28a745;
    font-weight: 600;
}

.points-table .exp-limit {
    color: #6c757d;
    font-size: 12px;
}

.level-notice {
    background: #fff3cd;
    border-left: 4px solid #ffc107;
    padding: 12px 16px;
    border-radius: 4px;
    font-size: 12px;
    color: #856404;
}

.level-notice p {
    margin: 0 0 8px 0;
}

.level-notice p:last-child {
    margin-bottom: 0;
}
</style>

