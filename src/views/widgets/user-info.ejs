                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #20B2AA 0%, #1a9a92 100%);">L2</span></td>
                        </tr>
                        <tr>
                            <td>L3</td>
                            <td>渐入佳境</td>
                            <td>300 - 599</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #4169E1 0%, #3559c5 100%);">L3</span></td>
                        </tr>
                        <tr>
                            <td>L4</td>
                            <td>炉火纯青</td>
                            <td>600 - 999</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #9370DB 0%, #7c5bc0 100%);">L4</span></td>
                        </tr>
                        <tr>
                            <td>L5</td>
                            <td>登峰造极</td>
                            <td>1000 - 1499</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #FF69B4 0%, #e55a9f 100%);">L5</span></td>
                        </tr>
                        <tr>
                            <td>L6</td>
                            <td>一代宗师</td>
                            <td>1500 - 2099</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #FF8C00 0%, #e57c00 100%);">L6</span></td>
                        </tr>
                        <tr>
                            <td>L7</td>
                            <td>绝世高手</td>
                            <td>2100 - 2799</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #DC143C 0%, #c11234 100%);">L7</span></td>
                        </tr>
                        <tr>
                            <td>L8</td>
                            <td>传奇人物</td>
                            <td>2800 - 3599</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #8B008B 0%, #750075 100%);">L8</span></td>
                        </tr>
                        <tr>
                            <td>L9</td>
                            <td>神话传说</td>
                            <td>3600 - 4499</td>
                            <td><span class="level-badge-small" style="background: linear-gradient(135deg, #FFD700 0%, #e5c100 100%);">L9</span></td>
                        </tr>
                        <tr>
                            <td>L10</td>
