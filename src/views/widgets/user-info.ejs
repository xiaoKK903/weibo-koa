<div class="user-info clear-fix">
    <img src="<%= userInfo.picture%>" class="header-img float-left"/>
    <div class="user-info-header">
        <h4 class="user-name"><%= userInfo.nickName%></h4>
        <div class="level-row">
            <span class="level-badge" id="user-level-badge" data-user-id="<%= userInfo.id%>">
                <span class="level-number">L1</span>
                <span class="level-name">初入江湖</span>
            </span>
            <a href="javascript:void(0)" class="level-rules-link" id="show-level-rules">
                <i class="fa fa-question-circle"></i> 等级规则
            </a>
        </div>
    </div>
</div>

<% if (isMe) { %>
    <%# 是当前登录用户%>
    <p class="bold margin-top-10">
        <a href="/at-me">
            @提到我的 (0)
        </a>
    </p>
<% } else { %>
    <%# 不是当前登录用户，显示关注按钮%>
    <div class="margin-top-10">
        <button class="btn btn-primary btn-sm follow-btn" data-user-id="<%= userInfo.id%>" data-followed="<%= amIFollowed%>">
            <%= amIFollowed ? '已关注' : '关注' %>
        </button>
    </div>
<% } %>

<div class="margin-top-10">
    <a href="/profile/<%= userInfo.userName %>/following" class="follow-count">关注 (<span class="following-count"><%= followersData ? followersData.count : 0%></span>)</a>
    <span class="margin-left-10 margin-right-10">|</span>
    <a href="/profile/<%= userInfo.userName %>/follower" class="fan-count">粉丝 (<span class="follower-count"><%= fansData ? fansData.count : 0%></span>)</a>
</div>

<style>
.user-info-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.level-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
}

.level-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    background: linear-gradient(135deg, #808080 0%, #696969 100%);
    color: white;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
}

.level-number {
    font-weight: bold;
    font-size: 13px;
}

.level-name {
    opacity: 0.95;
}

.level-progress-bar {
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    margin-top: 8px;
    overflow: hidden;
}

.level-progress-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s ease;
}

.level-exp-info {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: #999;
    margin-top: 4px;
}

.level-rules-link {
    font-size: 12px;
    color: #007bff;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 4px;
    transition: all 0.2s ease;
}

.level-rules-link:hover {
    background: rgba(0, 123, 255, 0.1);
    text-decoration: underline;
}

.level-rules-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: none;
    z-index: 99999;
}

.level-rules-modal-overlay.show {
    display: block;
}

.level-rules-modal {
    position: absolute;
